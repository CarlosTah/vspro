{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "useDefineForClassFields": false,
    "paths": {
      "@vspro/database": ["../../packages/database/src"],
      "@vspro/database/*": ["../../packages/database/src/*"],
      "@vspro/shared": ["../../packages/shared/src"],
      "@vspro/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/database/src/**/*",
    "../../packages/shared/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.isolation.spec.ts",
    "**/*.integration.spec.ts",
    "**/*.smoke.spec.ts"
  ]
}
