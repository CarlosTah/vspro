# ─────────────────────────────────────────────────────────────
# VSPRO — Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA commitear .env.local ni .env.production
# ─────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL=postgresql://vspro:vspro_dev_pass@localhost:5432/vspro_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=vspro_redis_dev

# ── JWT ───────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_SECRET_REAL_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=7d

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Meta (WhatsApp / Messenger / Instagram) ───────────────────
META_APP_ID=
META_APP_SECRET=
# Token de verificación para webhooks (puedes inventarlo, debe coincidir con el configurado en Meta)
META_WEBHOOK_VERIFY_TOKEN=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ── AWS S3 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=vspro-uploads-dev

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@vspro.app

# ── Facturapi (CFDI México) ───────────────────────────────────
FACTURAPI_KEY=

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000
