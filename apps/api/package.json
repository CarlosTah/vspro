{
  "name": "@vspro/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "node --require @swc-node/register src/main.ts",
    "start": "node dist/main",
    "lint": "eslint 'src/**/*.ts' --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:unit": "jest --testPathPattern='src/.*\\.spec\\.ts$' --testPathIgnorePatterns='integration|isolation|smoke'",
    "test:integration": "jest --testPathPattern='integration\\.spec\\.ts$' --runInBand",
    "test:isolation": "jest --testPathPattern='tenant-isolation\\.spec\\.ts$' --runInBand",
    "test:smoke": "jest --testPathPattern='smoke\\.spec\\.ts$' --runInBand",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/websockets": "^10.4.22",
    "@vspro/database": "*",
    "@vspro/shared": "*",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.2",
    "openai": "^4.77.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@swc/helpers": "^0.5.21",
    "@swc/register": "^0.1.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.1",
    "typescript": "^5.7.3"
  }
}
