{
  "name": "@vspro/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:test": "dotenv -e .env.test -- prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:staging": "ts-node prisma/seed-staging.ts",
    "db:seed:chaos": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-chaos.ts",
    "db:seed:vikids": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-vikids.ts",
    "db:seed:room359": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-room359.ts",
    "db:seed:tools:vikids": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-tools-vikids.ts",
    "db:seed:tools:room359": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-tools-room359.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
